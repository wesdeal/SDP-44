# ─────────────────────────────────────────────────────────────────────────────
# Pipeline Dashboard — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Backend base URL (no trailing slash).
# When set, the dashboard fetches live artifact data from this origin.
# Leave empty to use mock data (default for local development without backend).
#
# Example:
#   VITE_API_BASE=http://localhost:8000
VITE_API_BASE=http://localhost:8000

# Force mock mode even when VITE_API_BASE is set.
# Useful for UI work when the backend is temporarily unavailable.
# Accepted values: "true" | "false" (default: "false")
VITE_USE_MOCK=false

# Default run UUID to load on startup.
# Overridden by the ?runId= URL query parameter at runtime.
#
# Example:
#   VITE_DEFAULT_RUN_ID=299970a3-0f86-4c91-bc05-4e0f3995ee43
VITE_DEFAULT_RUN_ID=299970a3-0f86-4c91-bc05-4e0f3995ee43

# Base URL prefix for model evaluation plot images.
# The adapter resolves absolute filesystem plot paths (from artifact JSON) to:
#   {VITE_PLOT_BASE_URL}/{runId}/{filename}.png
#
# The Vite dev-server proxy forwards /plots/* to VITE_API_BASE/plots/*.
# For production, point this at your static file server or CDN prefix.
#
# Default: /plots  (handled by Vite proxy in dev mode)
VITE_PLOT_BASE_URL=/plots
